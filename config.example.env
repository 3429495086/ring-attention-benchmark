# Copy to benchmark.env and edit for a specific machine.

# Build paths. Leave empty when nvcc, MPI, and NCCL are already in the environment.
# CUDA_HOME=/usr/local/cuda
# MPI_HOME=/path/to/openmpi
# NCCL_HOME=/path/to/nccl

# External launcher settings used only by the example commands/scripts.
# MPIRUN=/path/to/mpirun
# HOSTFILE=hosts.txt
# MPIRUN_EXTRA_ARGS="--map-by ppr:4:node --bind-to none"
# SRUN=srun
# SRUN_MPI_TYPE="openmpi"
# SRUN_EXTRA_ARGS="--ntasks-per-node=1"

# Machine shape sweep. The outer batch/shell loop chooses these process counts.
NP_LIST="2 4 8"

# Benchmark controls.
WARMUP=10
ITERS=100
BACKENDS="staged staged_Isendrecv cuda_aware cuda_aware_Isendrecv nccl"
RUN_TYPES="comm attention"
# ALLOW_GPU_OVERSUBSCRIBE=1

# KV shard sizes in bytes.
COMM_SIZES="262144 524288 1048576 4194304 16777216"
ATTENTION_SIZES="262144 524288 1048576 4194304"

# Preparation controls for ./run_suite.sh.
BUILD=1
COLLECT_ENV=1
