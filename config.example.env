# Copy to benchmark.env and edit for a specific machine.

# Build paths. Leave empty when nvcc, mpirun, MPI, and NCCL are already in the environment.
# CUDA_HOME=/usr/local/cuda
# MPI_HOME=/path/to/openmpi
# NCCL_HOME=/path/to/nccl
# MPIRUN=/path/to/mpirun

# Launcher mode:
#   auto   - use srun inside a Slurm allocation, otherwise mpirun
#   mpirun - always use mpirun
#   srun   - always use srun
LAUNCHER="auto"

# Machine shape sweep. Use one value for a single node, several values for scaling.
NP_LIST="2 4 8"

# For OpenMPI multi-node runs, either use HOSTFILE or put the full flags here.
# HOSTFILE=hosts.txt
# MPIRUN_EXTRA_ARGS="--map-by ppr:4:node --bind-to none"

# For Slurm runs with srun launcher.
# SRUN_MPI_TYPE="openmpi"
# SRUN_EXTRA_ARGS="--ntasks-per-node=1"

# Benchmark controls.
WARMUP=10
ITERS=100
BACKENDS="staged staged_Isendrecv cuda_aware cuda_aware_Isendrecv nccl"
RUN_TYPES="comm attention"
# ALLOW_GPU_OVERSUBSCRIBE=1

# KV shard sizes in bytes.
COMM_SIZES="262144 524288 1048576 4194304 16777216"
ATTENTION_SIZES="262144 524288 1048576 4194304"

# Set BUILD=0 if the binaries are already compiled.
BUILD=1
COLLECT_ENV=1
